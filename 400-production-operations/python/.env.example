# PostgreSQL connection
DATABASE_URL=postgresql://workshop:workshop@localhost:5432/bookstore

# Valkey Cluster nodes (comma-separated host:port pairs)
# The client only needs one seed node to discover the topology,
# but multiple seeds provide resilience if the first is down.
VALKEY_CLUSTER_NODES=localhost:7001,localhost:7002,localhost:7003

# Cache configuration
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# Circuit breaker configuration
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN=30

# Connection pool configuration
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
